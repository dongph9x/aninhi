# Copy file này thành env/.env (hoặc env/.env.development / env/.env.production)
# rồi điền giá trị thật. KHÔNG commit file đã điền giá trị thật.

# Token Discord bot (Discord Developer Portal > Bot > Token)
BOT_TOKEN=

# development | production
NODE_ENV=development

# Debug namespace (xem package.json scripts: dev/start đều set DEBUG=bot:*)
DEBUG=bot:*

# Link invite Discord server hỗ trợ, hiện trong lệnh help
SUPPORT_GUILD_INVITE=

# Tên server/đội hỗ trợ, hiện trong footer lệnh help
SUPPORT_NAME=

# URL dashboard (nếu có)
DASHBOARD_URL=
